{
  "name": "@hopak/auth",
  "version": "0.1.0",
  "description": "Authentication for Hopak.js — JWT, credential signup/login, OAuth (GitHub + Google), and role-based access control.",
  "license": "MIT",
  "author": "Volodymyr Press <vladimpress@gmail.com>",
  "homepage": "https://github.com/hopakjs/hopak#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hopakjs/hopak.git",
    "directory": "packages/auth"
  },
  "bugs": {
    "url": "https://github.com/hopakjs/hopak/issues"
  },
  "keywords": ["hopak", "auth", "jwt", "oauth", "rbac", "github", "google"],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./oauth/github": "./src/oauth/github.ts",
    "./oauth/google": "./src/oauth/google.ts"
  },
  "files": ["src", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@hopak/common": "workspace:*",
    "@hopak/core": "workspace:*",
    "jose": "^5.6.0"
  },
  "devDependencies": {
    "@hopak/testing": "workspace:*",
    "jose": "^5.6.0"
  }
}
